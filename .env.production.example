# Copy this file to .env and populate ALL secrets before running the stack.
# Do NOT commit .env to source control.
#
# ── Deployment mode ───────────────────────────────────────────────────────────
# IP mode (no domain yet): uses nginx.ip.conf with port-based routing.
# Domain mode (after DNS + SSL): remove NGINX_CONF_FILE line entirely.
NGINX_CONF_FILE=./docker/nginx/nginx.ip.conf
SERVER_IP=YOUR_SERVER_IP

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=AlumniDb
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=alumat

# ── Storage (set STORAGE_CDN_ENDPOINT to public URL for file serving) ─────────
STORAGE_ACCESS_KEY=CHANGE_ME_MINIO_USER
STORAGE_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
STORAGE_BUCKET=alumat
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://alumni-minio:9000
STORAGE_CDN_ENDPOINT=http://YOUR_SERVER_IP:9000
# Domain mode CDN endpoint (uncomment after SSL):
# STORAGE_CDN_ENDPOINT=https://cdn-alumat.umat.edu.gh

# ── JWT Signing Keys (generate with: openssl rand -hex 32) ───────────────────
JWT_ISSUER=https://alumat.umat.edu.gh
JWT_AUDIENCE=https://alumat.umat.edu.gh
ADMIN_SIGNING_KEY=CHANGE_ME_replace_with_secure_random_key_64chars
MEMBER_SIGNING_KEY=CHANGE_ME_replace_with_secure_random_key_64chars

# ── SMTP (production email) ───────────────────────────────────────────────────
USE_SSL=false
USE_STARTTLS=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_SENDER_NAME=UMaT Alumni
SMTP_SENDER_EMAIL=noreply@alumat.umat.edu.gh

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxx
PAYSTACK_CALLBACK_URL=https://alumat.umat.edu.gh/contributions

# ── Frontend API URLs (baked into JS bundles at build time) ───────────────────
# IP mode — use IP:port values below.
# Domain mode — uncomment the https:// lines and remove the http:// ones.
NEXT_PUBLIC_ADMIN_API_URL=http://YOUR_SERVER_IP:8082/api/v1
NEXT_PUBLIC_MEMBER_API_URL=http://YOUR_SERVER_IP:8081/api/v1
# NEXT_PUBLIC_ADMIN_API_URL=https://admin-alumat-api.umat.edu.gh/api/v1
# NEXT_PUBLIC_MEMBER_API_URL=https://alumat-api.umat.edu.gh/api/v1

# ── Domain mode (uncomment when DNS is live and SSL is provisioned) ───────────
# NGINX_CONF_FILE=   ← remove this line entirely
# JWT_ISSUER=https://alumat.umat.edu.gh
# JWT_AUDIENCE=https://alumat.umat.edu.gh
# PAYSTACK_CALLBACK_URL=https://alumat.umat.edu.gh/contributions
# NEXT_PUBLIC_ADMIN_API_URL=https://admin-alumat-api.umat.edu.gh/api/v1
# NEXT_PUBLIC_MEMBER_API_URL=https://alumat-api.umat.edu.gh/api/v1
# STORAGE_CDN_ENDPOINT=https://cdn-alumat.umat.edu.gh
