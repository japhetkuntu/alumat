# Copy this file to .env and fill in any secrets before running the stack.
# You can leave the defaults as-is for local development.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=AlumniDb
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── MinIO (local object storage) ──────────────────────────────────────────────
MINIO_ROOT_USER=minioapp
MINIO_ROOT_PASSWORD=minioapp
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=alumat

# ── Storage (set to DO Spaces / S3 values in production) ──────────────────────
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://minio:9000
STORAGE_CDN_ENDPOINT=http://minio:9000

# ── MailHog ───────────────────────────────────────────────────────────────────
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ── JWT Signing Keys (generate strong random strings in production) ───────────
JWT_ISSUER=https://alumni.umat.edu.gh
JWT_AUDIENCE=https://alumni.umat.edu.gh
ADMIN_SIGNING_KEY=UMaT-Alumni-Admin-SuperSecretSigningKey-ChangeInProduction
MEMBER_SIGNING_KEY=UMaT-Alumni-Member-SuperSecretSigningKey-ChangeInProduction

# ── Paystack (get from dashboard.paystack.com) ────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxx
PAYSTACK_CALLBACK_URL=http://localhost:3200/contributions

# ── Frontend API URLs (baked into the JS bundle at build time) ────────────────
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:5100/api/v1
NEXT_PUBLIC_MEMBER_API_URL=http://localhost:5200/api/v1
